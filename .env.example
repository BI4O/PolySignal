# PolySignal 环境变量示例
# ============================================

# ============================================
# 场景 1：本地开发
# 使用方式：cp .env.example .env
# ============================================
HOSTNAME=0.0.0.0
PORT=3000
HOST_PORT=3000     # 本地 dev 不需要，保持默认即可

LANGGRAPH_HOST=localhost
LANGGRAPH_PORT=8123
NEXT_PUBLIC_LANGGRAPH_HOST=localhost
NEXT_PUBLIC_LANGGRAPH_PORT=8123
NEXT_PUBLIC_LANGGRAPH_GRAPH_ID=tokenage

# ============================================
# 场景 2：Docker 部署
# 使用方式：cp .env.example .env.docker
#
# 注意：docker-compose.yml 中的 environment 会覆盖
# LANGGRAPH_HOST 为 polybot-langgraph-api-1
# ============================================
# HOSTNAME=0.0.0.0
# PORT=3000
# HOST_PORT=3000
#
# LANGGRAPH_HOST=host.docker.internal
# LANGGRAPH_PORT=8123
# NEXT_PUBLIC_LANGGRAPH_HOST=localhost
# NEXT_PUBLIC_LANGGRAPH_PORT=8123
# NEXT_PUBLIC_LANGGRAPH_GRAPH_ID=base

# ============================================
# Reown AppKit (client-safe, wallet/login)
# ============================================
NEXT_PUBLIC_REOWN_PROJECT_ID=

# ============================================
# Polymarket CLOB API (server-side only)
# ============================================
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ============================================
# Polygon RPC (read on-chain USDC.e balance)
# ============================================
POLYGON_RPC_URL=
