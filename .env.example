# PolySignal frontend
HOSTNAME=0.0.0.0
PORT=3000          # port the Node.js server listens on inside the container
HOST_PORT=3000     # port exposed on your host machine (localhost)

# LangGraph backend (same naming as PolyBot .env)
LANGGRAPH_HOST=host.docker.internal
LANGGRAPH_PORT=8123
NEXT_PUBLIC_LANGGRAPH_HOST=localhost
NEXT_PUBLIC_LANGGRAPH_PORT=8123
